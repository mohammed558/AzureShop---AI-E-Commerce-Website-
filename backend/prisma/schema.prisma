datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  category    String
  color       String
  pattern     String
  rating      Float    @default(0)
  stock       Int      @default(0)
  image       String   // Existing, verified Unsplash URL (No placeholders)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([price])
}
